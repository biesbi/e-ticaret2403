<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Exclude uploads, assets and api directories from page rewrites
  RewriteRule ^(uploads|assets|public|api)/ - [L]

  # Public pages: remove .html from visible URLs
  RewriteCond %{THE_REQUEST} \s/+(hakkimizda|iletisim|siparis-takip|mesafeli-satis-sozlesmesi|iade-cayma-kosullari|gizlilik-politikasi|collector|verify-email|sifremi-unuttum|sifre-sifirla)\.html(?:[\s?]|$) [NC]
  RewriteRule ^ %1 [R=301,L,NE]

  # Public pages: serve extensionless URLs from the matching .html file
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(hakkimizda|iletisim|siparis-takip|mesafeli-satis-sozlesmesi|iade-cayma-kosullari|gizlilik-politikasi|collector|verify-email|sifremi-unuttum|sifre-sifirla)/?$ $1.html [L,NC]

  # Handle React Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
