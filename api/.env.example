# BoomerItems environment variables
# Copy this file as .env and fill in the values.

# Database
DB_HOST=localhost
DB_NAME=boomeritems
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=buraya_en_az_64_karakter_rastgele_bir_deger_yaz
JWT_EXPIRE=604800

# App
APP_ENV=production
APP_URL=https://www.boomeritems.com
ALLOWED_ORIGIN=https://www.boomeritems.com

# Upload
UPLOAD_DIR=../public/uploads
UPLOAD_MAX_MB=5

# Rate limit
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=300

# Email / SMTP
MAIL_ENABLED=true
MAIL_HOST=smtp.mnic.tr
MAIL_PORT=587
MAIL_SECURE=tls
MAIL_ALLOW_SELF_SIGNED=true
MAIL_VERIFICATION_EXPIRE_HOURS=24
MAIL_USER=info@boomeritems.com
MAIL_PASS=BURAYA_MAIL_SIFRESI_YAZIN
MAIL_FROM_EMAIL=info@boomeritems.com
MAIL_FROM_NAME=BoomerItems
MAIL_ADMIN_EMAIL=boomeritems@gmail.com

# Logging
LOG_ENABLED=true
LOG_DIR=./logs

FREE_SHIPPING_THRESHOLD=2500

# PayTR Odeme Entegrasyonu
# PayTR merchant panelinden alinacak bilgiler: https://www.paytr.com/magaza/ayarlar
PAYTR_ENABLED=true
PAYTR_TEST_MODE=1
PAYTR_USE_MOCK=false
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_CALLBACK_URL=https://www.boomeritems.com/api/payments/paytr/callback
PAYTR_CURRENCY=TL
PAYTR_TIMEOUT=30
PAYTR_NO_INSTALLMENT=0
PAYTR_MAX_INSTALLMENT=0
PAYTR_TEST_USER_IP=
